# ============================================================
# BILLING RADIUS - KONFIGURASI ENVIRONMENT
# Salin file ini ke .env dan isi nilainya
# ============================================================

# === SERVER ===
PORT=3000
NODE_ENV=development
APP_URL=http://localhost:3000
FRONTEND_URL=http://localhost:5173

# === DATABASE ===
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=billing_radius
DB_USER=root
DB_PASS=password_db_anda

# === JWT (WAJIB diganti — server menolak start jika masih default/kosong/<32 char) ===
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=ganti_dengan_secret_key_yang_sangat_panjang_dan_acak
JWT_EXPIRES=8h

# === WHATSAPP GATEWAY ===
# CATATAN: Konfigurasi WhatsApp (mode, provider, token, nomor pengirim)
# TIDAK lagi diatur lewat .env — sekarang disimpan di database (tabel
# `setting`) dan diatur langsung dari dashboard admin, menu WhatsApp.
# Variabel di bawah ini sengaja TIDAK ADA lagi karena sudah dipindah.
# Lihat docs/README.md bagian "Konfigurasi WhatsApp Gateway" untuk caranya.

# === PAYMENT GATEWAY ===
# Provider: midtrans | xendit | duitku | tripay
PG_PROVIDER=midtrans
PG_SANDBOX=true

# Midtrans
MIDTRANS_SERVER_KEY=SB-Mid-server-xxxxxxxxxxxx
MIDTRANS_CLIENT_KEY=SB-Mid-client-xxxxxxxxxxxx

# Xendit (alternatif)
XENDIT_SECRET_KEY=xnd_development_xxxxxxxxxx
XENDIT_WEBHOOK_TOKEN=token_webhook_xendit

# Duitku (alternatif)
DUITKU_MERCHANT_CODE=Dxxxx
DUITKU_API_KEY=api_key_duitku

# === FREERADIUS ===
RADIUS_HOST=127.0.0.1
RADIUS_SECRET=testing123

# === AUTOMATION ===
# Jam cron (format: jam)
CRON_REMINDER_JAM=8        # Jam kirim reminder tagihan
CRON_SUSPEND_JAM=9         # Jam cek & suspend otomatis
CRON_INVOICE_TANGGAL=1     # Tanggal generate invoice bulanan

# Berapa hari sebelum jatuh tempo kirim reminder
REMINDER_H_MINUS=3

# Berapa hari setelah jatuh tempo auto-suspend
SUSPEND_H_PLUS=3
