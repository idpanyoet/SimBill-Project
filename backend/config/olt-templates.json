{
  "_catatan": "Template registrasi ONU. Placeholder: {CARDPON}=pon tanpa rak (mis 8/2), {ONT}=nomor onu, {SN}=serial, {PROFILE}=bandwidth (mis 100M), {USER_PPPOE}/{PASSWORD_PPPOE}=kredensial PPPoE (otomatis dari radcheck kalau ditautkan). Baris '!' = pindah context (engine ubah jadi exit). JANGAN tulis 'configure terminal'/'end'/'write' di sini, engine yang nambahin. Kamu bebas edit/tambah template.",

  "zte": {
    "label": "ZTE (SFU / simpel)",
    "hgu": false,
    "lines": [
      "interface gpon-onu_1/{CARDPON}:{ONT}",
      "name {NAME}",
      "tcont 1 name PPPOE profile {PROFILE}",
      "tcont 2 name HOTSPOT profile {PROFILE}",
      "tcont 3 name ACS profile {PROFILE}",
      "gemport 1 name PPPOE tcont 1",
      "gemport 1 traffic-limit upstream {PROFILE} downstream {PROFILE}",
      "gemport 2 name HOTSPOT tcont 2",
      "gemport 2 traffic-limit upstream {PROFILE} downstream {PROFILE}",
      "gemport 3 name ACS tcont 3",
      "gemport 3 traffic-limit upstream {PROFILE} downstream {PROFILE}",
      "service-port 1 vport 1 user-vlan 300 vlan 300",
      "service-port 1 description PPPOE",
      "service-port 2 vport 2 user-vlan 400 vlan 400",
      "service-port 2 description HOTSPOT",
      "service-port 3 vport 3 user-vlan 102 vlan 102"
    ]
  },

  "huawei": {
    "label": "Huawei / HGU",
    "hgu": true,
    "lines": [
      "interface gpon-onu_1/{CARDPON}:{ONT}",
      "sn-bind enable sn",
      "tcont 1 name PPPOE profile {PROFILE}",
      "tcont 2 name HOTSPOT profile {PROFILE}",
      "tcont 3 name ACS profile {PROFILE}",
      "gemport 1 name PPPOE tcont 1",
      "gemport 1 traffic-limit upstream {PROFILE} downstream {PROFILE}",
      "gemport 2 name HOTSPOT tcont 2",
      "gemport 2 traffic-limit upstream {PROFILE} downstream {PROFILE}",
      "gemport 3 name ACS tcont 3",
      "gemport 3 traffic-limit upstream {PROFILE} downstream {PROFILE}",
      "switchport mode hybrid vport 1",
      "service-port 1 vport 1 user-vlan 300 vlan 300",
      "service-port 2 vport 2 user-vlan 400 vlan 400",
      "service-port 3 vport 3 user-vlan 102 vlan 102",
      "port-identification format DSL-FORUM-PON sport 1",
      "!",
      "pon-onu-mng gpon-onu_1/{CARDPON}:{ONT}",
      "service PPPOE gemport 1 vlan 300",
      "service HOTSPOT gemport 2 vlan 400",
      "service ACS gemport 3 vlan 102",
      "switchport-bind switch_0/1 iphost 1",
      "switchport-bind switch_0/2 iphost 2",
      "switchport-bind switch_0/3 iphost 3"
    ]
  },

  "f670l": {
    "label": "ZTE F670L (HGU + WiFi)",
    "hgu": true,
    "lines": [
      "interface gpon-onu_1/{CARDPON}:{ONT}",
      "tcont 1 name PPPOE profile {PROFILE}",
      "tcont 2 name HOTSPOT profile {PROFILE}",
      "tcont 3 name ACS profile {PROFILE}",
      "gemport 1 name PPPOE tcont 1",
      "gemport 1 traffic-limit upstream {PROFILE} downstream {PROFILE}",
      "gemport 2 name HOTSPOT tcont 2",
      "gemport 2 traffic-limit upstream {PROFILE} downstream {PROFILE}",
      "gemport 3 name ACS tcont 3",
      "gemport 3 traffic-limit upstream {PROFILE} downstream {PROFILE}",
      "service-port 1 vport 1 user-vlan 300 vlan 300",
      "service-port 2 vport 2 user-vlan 400 vlan 400",
      "service-port 3 vport 3 user-vlan 102 vlan 102",
      "service-port 1 description PPPOE",
      "service-port 2 description HOTSPOT",
      "!",
      "pon-onu-mng gpon-onu_1/{CARDPON}:{ONT}",
      "service PPPOE gemport 1 vlan 300",
      "service HOTSPOT gemport 2 vlan 400",
      "service ACS gemport 3 vlan 102",
      "wan-ip 1 mode pppoe username {USER_PPPOE} password {PASSWORD_PPPOE} vlan-profile PPPOE host 1",
      "wan-ip 1 ping-response enable traceroute-response enable",
      "security-mgmt 1 state enable mode forward protocol web telnet",
      "interface wifi wifi_0/2 state unlock",
      "ssid auth wep wifi_0/2 open-system",
      "ssid ctrl wifi_0/2 name RFNET.ID",
      "vlan port wifi_0/2 mode tag vlan 400",
      "interface wifi wifi_0/6 state unlock",
      "ssid auth wep wifi_0/6 open-system",
      "ssid ctrl wifi_0/6 name RFNET.ID",
      "vlan port wifi_0/6 mode tag vlan 400"
    ]
  },

  "gm220s": {
    "label": "GM220S (HGU)",
    "hgu": true,
    "lines": [
      "interface gpon-onu_1/{CARDPON}:{ONT}",
      "tcont 1 name PPPOE profile {PROFILE}",
      "tcont 2 name HOTSPOT profile {PROFILE}",
      "tcont 3 name ACS profile {PROFILE}",
      "gemport 1 name PPPOE tcont 1",
      "gemport 1 traffic-limit downstream {PROFILE}",
      "gemport 2 name HOTSPOT tcont 2",
      "gemport 2 traffic-limit downstream {PROFILE}",
      "gemport 3 name ACS tcont 3",
      "gemport 3 traffic-limit downstream {PROFILE}",
      "service-port 1 vport 1 user-vlan 300 vlan 300",
      "service-port 2 vport 2 user-vlan 400 vlan 400",
      "service-port 3 vport 3 user-vlan 102 vlan 102",
      "service-port 1 description PPPOE",
      "service-port 2 description HOTSPOT",
      "service-port 3 description ACS",
      "!",
      "pon-onu-mng gpon-onu_1/{CARDPON}:{ONT}",
      "service PPPOE gemport 1 iphost 1 vlan 300",
      "service HOTSPOT gemport 2 vlan 400",
      "service ACS gemport 3 vlan 102",
      "pppoe 1 nat enable user {USER_PPPOE} password {PASSWORD_PPPOE}",
      "vlan port wifi_0/1 mode tag vlan 300",
      "vlan port wifi_0/2 mode tag vlan 400"
    ]
  }
}
